# PostgreSQL connection used by the dashboard and GitHub Actions pipeline.
# Use the Neon owner/admin URL for GitHub Actions and a read-only URL for Vercel.
DATABASE_URL=postgresql://dashboard_reader:replace_with_password@replace-with-neon-pooler-host/CustomerHealth?sslmode=require&channel_binding=require

# Optional raw table overrides for scripts/transform_train.py.
RAW_SCHEMA=raw
RAW_TABLE=customer_churn

# Chatbot settings.
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Optional Airbyte sync trigger route.
AIRBYTE_API_TOKEN=replace_with_airbyte_api_token
AIRBYTE_CONNECTION_ID=replace_with_airbyte_connection_id
AIRBYTE_API_BASE_URL=https://api.airbyte.com/v1
